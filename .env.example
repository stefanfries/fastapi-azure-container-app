# Azure Container Registry Configuration
DOCKER_OWNER=your-github-username
DOCKER_PASSWORD=your-github-token-or-pat

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=rg-FastAPI-AzureContainerApp-dev
AZURE_CONTAINER_APP_NAME=ca-fastapi
AZURE_ENVIRONMENT=managedEnvironment-rgFastAPIAzureC-a4a6

# MongoDB Configuration
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/
DB_NAME=finhub

# OpenFIGI API Configuration
# Optional - without a key the free tier applies (25 req/min).
# Sign up at https://www.openfigi.com/user/signup to obtain a key.
OPENFIGI_API_KEY=your-openfigi-api-key

# Cache Configuration
# Number of days before a cached instrument record is considered stale and re-fetched from comdirect.
# Default: 7
# INSTRUMENT_CACHE_TTL_DAYS=7

# API Key Protection
# Set a strong random value to require X-API-Key on all data endpoints.
# Leave this variable unset (or remove it) to run in open mode (local development only).
# IMPORTANT: an empty value (API_KEY=) is rejected at startup — the value must be non-empty.
# Production: set this as an Azure Container App secret instead of committing it here.
# API_KEY=your-secret-api-key
