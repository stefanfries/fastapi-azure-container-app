# Azure Container Registry Configuration
DOCKER_OWNER=your-github-username
DOCKER_PASSWORD=your-github-token-or-pat

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_RESOURCE_GROUP=rg-FastAPI-AzureContainerApp-dev
AZURE_CONTAINER_APP_NAME=ca-fastapi
AZURE_ENVIRONMENT=managedEnvironment-rgFastAPIAzureC-a4a6

# OpenFIGI API Configuration
# Optional - without a key the free tier applies (25 req/min).
# Sign up at https://www.openfigi.com/user/signup to obtain a key.
OPENFIGI_API_KEY=your-openfigi-api-key

# Optional: Application Configuration
# Add any application-specific environment variables here
# DATABASE_URL=your-database-connection-string
# API_KEY=your-api-key
